generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          String     @default("user")
  documents     Document[]
  comments      Comment[]
  photos        Photo[]
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  summary     String?
  content     String?
  coverImage  String?
  published   Boolean      @default(false)
  publishedAt DateTime?
  views       Int          @default(0)
  type        DocumentType

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  categoryId String?
  category   Document? @relation("DocumentCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  documents  Document[] @relation("DocumentCategory")

  parentId String?
  parent   Document?   @relation("DocumentTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Document[]  @relation("DocumentTree")

  tags                  DocumentTag[]
  comments              Comment[]
  outgoingRelations     DocumentRelation[] @relation("OutgoingRelations")
  incomingRelations     DocumentRelation[] @relation("IncomingRelations")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([published, createdAt(sort: Desc)])
  @@index([type, published, publishedAt(sort: Desc)])
  @@index([categoryId])
  @@index([parentId])
}

enum DocumentType {
  POST
  NOTE
  PAGE
  CATEGORY
}

model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  slug      String        @unique
  documents DocumentTag[]
  photos    PhotoTag[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model DocumentTag {
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tagId      String
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@index([tagId])
}

model DocumentRelation {
  id             String       @id @default(cuid())
  fromDocumentId String
  toDocumentId   String
  relationType   RelationType @default(BACKLINK)

  fromDocument Document @relation("OutgoingRelations", fields: [fromDocumentId], references: [id], onDelete: Cascade)
  toDocument   Document @relation("IncomingRelations", fields: [toDocumentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([fromDocumentId])
  @@index([toDocumentId])
}

enum RelationType {
  BACKLINK
  REFERENCE
  RELATED
  QUOTE
}

model Comment {
  id          String  @id @default(cuid())
  content     String
  authorName  String
  authorEmail String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  approved Boolean @default(false)

  // AI moderation annotations (advisory; null when unmoderated / fail-open)
  moderationLabel  String?   // "spam" | "toxic" | "normal"
  moderationScore  Float?    // risk 0..1
  moderationReason String?
  moderationAction String?   // policy recommendation: approve | flag-for-review | reject
  moderatedAt      DateTime?

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId])
  @@index([userId])
}

model Photo {
  id          String    @id @default(cuid())
  title       String
  imageUrl    String
  description String?
  order       Int       @default(0)
  published   Boolean   @default(true)

  authorId    String
  author      User      @relation(fields: [authorId], references: [id])

  tags        PhotoTag[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, order])
}

model PhotoTag {
  photoId String
  photo   Photo  @relation(fields: [photoId], references: [id], onDelete: Cascade)
  tagId   String
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([photoId, tagId])
  @@index([tagId])
}
