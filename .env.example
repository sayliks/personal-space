# Database (Supabase)
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# Auth.js
AUTH_SECRET="your-secret-at-least-32-chars"
AUTH_URL="http://localhost:3000"

# GitHub OAuth (optional — for comment section sign-in)
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# Admin seed
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme123"

# --- Experimental: embeddings / semantic search (optional) ---
# Only needed for the spike scripts in prisma/scripts (poc-embeddings*, discover-mimo-api).
# The app itself runs without these. Leave unset unless you're exploring vector search.
#
# Generic OpenAI-compatible provider (recommended — works with most Chinese providers):
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL="https://api.openai.com/v1"
# EMBEDDING_MODEL="text-embedding-3-small"
#
# Provider-specific keys (used by individual spike scripts):
# OPENAI_API_KEY=
# MIMO_API_KEY=

# --- Comment moderation (optional) ---
# When unset, comments still work and land in the pending queue unmoderated
# ("Not checked"). Setting these adds an advisory AI label/score/reason to each
# pending comment — the admin still approves manually. Fail-open: any error or
# missing key falls back to manual review and never blocks the commenter.
# Works with any OpenAI-compatible endpoint (OpenAI, DashScope, Zhipu, MiMO...).
# MODERATION_API_KEY=
# MODERATION_BASE_URL="https://api.openai.com/v1"
# MODERATION_MODEL="gpt-4o-mini"
